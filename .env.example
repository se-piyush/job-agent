# ── LLM selection ─────────────────────────────────────────────────────────────
# Set LLM_MODEL to switch providers without touching code.
# If unset, defaults to anthropic/claude-sonnet-4-6.
#
# Examples:
#   LLM_MODEL=anthropic/claude-sonnet-4-6        (default)
#   LLM_MODEL=ollama/qwen2.5:72b                 (local, free)
#   LLM_MODEL=ollama/llama3.3:70b                (local, free)
#   LLM_MODEL=together_ai/Qwen/Qwen2.5-72B-Instruct
#   LLM_MODEL=fireworks_ai/accounts/fireworks/models/qwen2p5-72b-instruct
#   LLM_MODEL=openrouter/qwen/qwen-2.5-72b-instruct
LLM_MODEL=anthropic/claude-sonnet-4-6

# ── API keys (only the one matching your LLM_MODEL is required) ───────────────
ANTHROPIC_API_KEY=sk-ant-...
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=

# ── Ollama (only needed if LLM_MODEL starts with ollama/) ─────────────────────
# Defaults to http://localhost:11434 if unset.
# OLLAMA_BASE_URL=http://localhost:11434
