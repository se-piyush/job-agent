# ── Per-agent model selection ──────────────────────────────────────────────────
# Each agent has its own default tuned for cost vs. quality.
# Override any one without touching the others.
# CLI --model flag overrides ALL agents for that run.
#
# Resume needs exact HTML with strict rules → Haiku (~$0.014/run)
RESUME_MODEL=anthropic/claude-haiku-4-5-20251001
#
# Search, match, email are tool-calling / free-form → Groq free tier
SEARCH_MODEL=groq/llama-3.3-70b-versatile
MATCH_MODEL=groq/llama-3.3-70b-versatile
EMAIL_MODEL=groq/llama-3.3-70b-versatile
#
# Global override — sets ALL agents to one model (useful for testing)
# LLM_MODEL=anthropic/claude-sonnet-4-6

# ── API keys ───────────────────────────────────────────────────────────────────
# Anthropic (required if any *_MODEL starts with anthropic/)
ANTHROPIC_API_KEY=sk-ant-...

# Groq — free tier, sign up at console.groq.com
GROQ_API_KEY=gsk_...

# Optional cloud providers
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=

# ── Ollama (only needed if any *_MODEL starts with ollama/) ───────────────────
# Defaults to http://localhost:11434 if unset.
# OLLAMA_BASE_URL=http://localhost:11434
